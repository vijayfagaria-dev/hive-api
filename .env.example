# Copy to .env and fill in. Never commit .env.
# NOTE: the Telegram bot was retired in v4 — this is now a web-first app. The old
# TELEGRAM_BOT_TOKEN / WEBHOOK_BASE_URL settings are gone.

# Public base URL of the web app — used to deep-link notifications to a complaint.
APP_BASE_URL=https://hive.example.com

# Signs web login session cookies (HMAC). Set a long random string before exposing
# logins — an unset/default key makes sessions forgeable. (WEBHOOK_SECRET is still
# read as a legacy fallback if SECRET_KEY is unset.)
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(24))"
SECRET_KEY=

DATABASE_PATH=hive.db
WALLET_UPI_QR_URL=

# --- Notifications: Web Push (VAPID) + email fallback (both free; optional) ---
# Web Push works on Android + installed iOS PWAs (16.4+). Generate VAPID keys once:
#   python -c "from py_vapid import Vapid01 as V; v=V(); v.generate_keys(); \
#     import base64;
#     print('public', base64.urlsafe_b64encode(v.public_key.public_bytes(__import__('cryptography').hazmat.primitives.serialization.Encoding.X962, __import__('cryptography').hazmat.primitives.serialization.PublicFormat.UncompressedPoint)).decode().rstrip('='))"
# (or use the `web-push` npm CLI: `npx web-push generate-vapid-keys`)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@hive.example.com

# Email fallback (catches iPhone users who don't install the PWA). Empty SMTP_HOST
# disables it. With Gmail, use an App Password.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=Hive <no-reply@hive.example.com>
SMTP_STARTTLS=true

# --- WhatsApp (official Meta Cloud API; optional) ---
# Empty WHATSAPP_TOKEN/PHONE_NUMBER_ID disables it. Free dev tier fits a small flat
# (send to up to 5 verified test numbers). One-time setup at developers.facebook.com:
#   1. Create a Meta app -> add the "WhatsApp" product -> note the Phone number ID.
#   2. Create a permanent System User token with whatsapp_business_messaging scope.
#   3. Add each flatmate's number as a recipient (dev tier) and have them accept.
#   4. Create a MESSAGE TEMPLATE named below, category "Utility", language "en",
#      whose BODY is exactly:   Hive 🐝 {{1}}
#      (one variable; we fill {{1}} with the alert text + complaint link).
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAME=hive_alert
WHATSAPP_TEMPLATE_LANG=en
WHATSAPP_API_VERSION=v21.0

# "Getting here" guest card (all optional — the card hides if these are unset).
# FLAT_LAT/LNG power the map + Uber/Ola ride links; FLAT_ADDRESS is shown + copyable.
FLAT_ADDRESS=
FLAT_LAT=
FLAT_LNG=
FLAT_PLACE_NAME=Hive

# Optional tuning (defaults shown):
COOLING_HOURS=12
SWEEP_INTERVAL_SECONDS=300
# Set true in production (behind HTTPS) so the login cookie is HTTPS-only.
COOKIE_SECURE=false

# --- Complaint workflow (proof + accept/deny + voting) ---
# Hours a denied complaint's vote stays open before it auto-finalizes.
VOTE_WINDOW_HOURS=24
# Where uploaded image proofs are written (gitignored).
PROOF_STORAGE_DIR=proofs
# Max size per uploaded proof image, in bytes (default 8 MiB).
MAX_PROOF_BYTES=8388608
# Anti-spam: max complaints one member can file per rolling 24h (0 = no cap).
MAX_COMPLAINTS_PER_DAY=8
# Anti-dupe: block the same accuser re-filing the same accused+rule within this
# many hours (0 = off).
DUPLICATE_WINDOW_HOURS=6

# --- Rule proposals (community vote to change the rule book) ---
# Voting window for a submitted proposal.
PROPOSAL_VOTING_HOURS=72
# Passing conditions at close: >= quorum tenant participants, yes-share >= pass%, and yes >= min.
PROPOSAL_QUORUM=2
PROPOSAL_PASS_PCT=60
PROPOSAL_MIN_YES=2
# Require an admin (tenant) to approve a proposal before voting opens (false = opens on submit).
PROPOSAL_REQUIRE_REVIEW=false
# Anti-spam: max proposals/member/24h, and a minimum rationale length to submit.
PROPOSAL_MAX_PER_DAY=5
PROPOSAL_MIN_BODY_LEN=10
