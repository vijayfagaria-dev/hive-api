# hive-api production .env  →  copy to /opt/hive/hive-api/.env  (chmod 600)
# Generate the secrets ON THE SERVER (don't paste real ones into chat/git).

# --- App / sessions ---
APP_BASE_URL=https://hive-flat.duckdns.org
SECRET_KEY=__run: python3 -c "import secrets; print(secrets.token_urlsafe(48))"__
COOKIE_SECURE=true

# --- Storage (persistent disk) ---
DATABASE_PATH=/var/lib/hive/hive.db
PROOF_STORAGE_DIR=/var/lib/hive/proofs

# --- Web Push (free) — run: npx web-push generate-vapid-keys ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# --- Email fallback (Gmail App Password — free) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=youraddress@gmail.com
SMTP_PASSWORD=__16-char Gmail App Password__
SMTP_FROM=Hive 🐝 <youraddress@gmail.com>
SMTP_STARTTLS=true

# --- WhatsApp Cloud API (Meta, dev tier — free for <=5 test recipients) ---
WHATSAPP_TOKEN=__permanent System User token__
WHATSAPP_PHONE_NUMBER_ID=__from WhatsApp > API Setup__
WHATSAPP_TEMPLATE_NAME=hive_alert
WHATSAPP_TEMPLATE_LANG=en
WHATSAPP_API_VERSION=v21.0

# --- Optional ---
WALLET_UPI_QR_URL=
FLAT_ADDRESS=
FLAT_LAT=
FLAT_LNG=
FLAT_PLACE_NAME=Hive
